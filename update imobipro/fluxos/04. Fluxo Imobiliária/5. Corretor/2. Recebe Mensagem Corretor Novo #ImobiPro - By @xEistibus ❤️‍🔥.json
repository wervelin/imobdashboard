      "parameters": {
        "jsCode": "// Pegando o item (primeiro elemento do array)\nconst item = $input.item.json;\n\n// Contando quantas propriedades tem no objeto\nconst quantidadeDePropriedades = Object.keys(item).length;\n\n// Se tiver até 3 propriedades, retornamos 'conversation'\nif (quantidadeDePropriedades <= 3) {\n\treturn [\n\t\t{\n\t\t\tjson: { result: 'conversation' }\n\t\t}\n\t];\n}\n\n// Se tiver 4 ou mais propriedades, retornamos 'content'\nreturn [\n\t{\n\t\tjson: { result: 'content' }\n\t}\n];\n"
