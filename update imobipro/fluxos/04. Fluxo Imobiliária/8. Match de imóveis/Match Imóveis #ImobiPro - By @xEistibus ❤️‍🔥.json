        "jsCode": "// Pega o conteúdo do campo 'content' e faz o parse do JSON\nconst data = JSON.parse($json.content).data;\n\n// Mapeia os dados dos interessados\nreturn data.map((item) => {\n  const { nome, telefone, bairro_interesse, imagens, imovel } = item;\n\n  return {\n    json: {\n      nome,\n      telefone,\n      bairro_interesse,\n      imagens,\n      imovel: {\n        endereco: imovel.endereco,\n        bairro: imovel.bairro,\n        cidade: imovel.cidade,\n        tipo_imovel: imovel.tipo_imovel,\n        tamanho_m2: imovel.tamanho_m2,\n        quartos: imovel.quartos,\n        banheiros: imovel.banheiros,\n        suite: imovel.suite,\n        preco: imovel.preco,\n        listing_id: imovel.listing_id,\n        descricao: imovel.descricao\n      }\n    }\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
