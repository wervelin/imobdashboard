    {
      "parameters": {
        "jsCode": "// 1. Coleta os dados do webhook e da lista de clientes interessados\nconst imovel = $('Webhook').first().json.body;\nconst clientes = items;\n\n// 2. Validação básica\nif (!imovel.bairro || !Array.isArray(imovel.imagens)) {\n  throw new Error(\"Imóvel deve ter 'bairro' e 'imagens' definidas.\");\n}\n\n// 3. Função para embaralhar e pegar 5 imagens aleatórias\nfunction pegarImagensAleatorias(imagens) {\n  return imagens\n    .sort(() => 0.5 - Math.random())\n    .slice(0, 5);\n}\n\n// 4. Filtra e mapeia os clientes\nconst resultado = clientes\n  .filter(cli => cli.json.nome && cli.json.telefone)\n  .map(cli => {\n    return {\n      json: {\n        nome: cli.json.nome,\n        telefone: cli.json.telefone,\n        bairro_interesse: cli.json.bairro,\n        imagens: pegarImagensAleatorias(imovel.imagens),\n        imovel: {\n          endereco: imovel.endereco,\n          bairro: imovel.bairro,\n          cidade: imovel.cidade,\n          tipo_imovel: imovel.tipo_imovel,\n          tamanho_m2: imovel.tamanho_m2,\n          quartos: imovel.quartos,\n          banheiros: imovel.banheiros,\n          suite: imovel.suite,\n          preco: imovel.preco,\n          listing_id: imovel.listing_id,\n          descricao: imovel.descricao ?? null\n        }\n      }\n    };\n  });\n\n// 5. Retorno final\nreturn resultado;\n"
      },
